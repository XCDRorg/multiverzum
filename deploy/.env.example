# ============================================================================
# multiversum.cloud Third Room stack — environment
# Copy to `.env`, fill in the SECRET values, NEVER commit the real .env.
# Generate each secret with:  openssl rand -hex 32
# ============================================================================

# --- Domains (already decided) ---
SERVER_NAME=multiversum.cloud                 # the suffix in @you:multiversum.cloud
SYNAPSE_HOST=matrix.multiversum.cloud         # where Synapse actually listens
MAS_HOST=auth.multiversum.cloud               # where MAS (auth) listens
FRONTEND_HOST=multiversum.cloud               # Third Room web client
REGISTRY_HOST=registry.xcdr.org               # self-hosted image registry

# --- Postgres ---
POSTGRES_USER=matrix
POSTGRES_PASSWORD=CHANGE_ME_pg_password
POSTGRES_DB_SYNAPSE=synapse
POSTGRES_DB_MAS=mas

# --- Shared secrets between Synapse and MAS (MSC3861 wiring) ---
# These three must match across synapse/homeserver.yaml and mas/config.yaml.
MAS_CLIENT_SECRET=CHANGE_ME_mas_client_secret      # synapse<->mas client auth
MAS_ADMIN_TOKEN=CHANGE_ME_mas_admin_token          # synapse admin provisioning
MAS_MATRIX_SECRET=CHANGE_ME_mas_matrix_secret      # mas->synapse admin API

# --- MAS internal crypto (generate with: openssl rand -hex 32) ---
MAS_ENCRYPTION_SECRET=CHANGE_ME_64_hex_chars

# --- Authentik upstream OIDC (from your OPNsense Authentik) ---
# Create an OAuth2/OpenID provider+application in Authentik for MAS, then:
AUTHENTIK_ISSUER=https://auth.your-authentik-domain/application/o/matrix-mas/
AUTHENTIK_CLIENT_ID=CHANGE_ME_from_authentik
AUTHENTIK_CLIENT_SECRET=CHANGE_ME_from_authentik

# --- coturn ---
TURN_SECRET=CHANGE_ME_turn_shared_secret
TURN_REALM=multiversum.cloud
# Public IP of the server (coturn needs to advertise it for WebRTC):
TURN_EXTERNAL_IP=CHANGE_ME_server_public_ip

# --- Registry basic auth (rig pushes with these) ---
REGISTRY_USER=rig
REGISTRY_PASSWORD=CHANGE_ME_registry_password
